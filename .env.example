# ── SEC Filing RAG Pipeline — environment variables ──────────────────────────
# Copy to .env and fill in only what you need.
# The OFFLINE defaults (no API keys, no downloads) work out of the box.

# ── Ingestion ──────────────────────────────────────────────────────────────
# EDGAR requires a descriptive User-Agent with a contact email.
SEC_USER_AGENT="SEC-RAG-Pipeline/1.0 (contact: you@example.com)"
SEC_EDGAR_BASE_URL="https://data.sec.gov"
SEC_RATE_LIMIT_RPS=8          # stay well under EDGAR's 10 req/s limit
SEC_DATA_DIR="./data"         # where raw filings are stored (bronze layer)

# ── Watermark / incremental ingestion ─────────────────────────────────────
# ISO date string; only filings filed ON OR AFTER this date are fetched.
# Leave blank to fetch all available. Updated automatically each run.
SEC_WATERMARK_DATE=""

# ── Embedding backend ──────────────────────────────────────────────────────
# Options: "hashing" (offline default), "sentence_transformers", "openai"
SEC_EMBEDDER="hashing"
SEC_EMBED_DIM=384             # must match the model; hashing uses this value
SEC_EMBED_MODEL="BAAI/bge-small-en-v1.5"   # used only for sentence_transformers

# OpenAI embeddings (only if SEC_EMBEDDER=openai)
# OPENAI_API_KEY="sk-..."

# ── Vector store ──────────────────────────────────────────────────────────
# Options: ":memory:" | "./qdrant_data" (embedded, persisted) | "http://host:port"
SEC_QDRANT_LOCATION="./qdrant_data"
SEC_QDRANT_COLLECTION="sec_chunks"

# ── LLM backend (generation) ──────────────────────────────────────────────
# Options: "none" (retrieval-only, default), "openai", "anthropic", "groq"
SEC_LLM_PROVIDER="none"
SEC_LLM_MODEL=""              # e.g. "gpt-4o-mini", "claude-haiku-4-5-20251001", "llama3-8b-8192"
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
# GROQ_API_KEY="gsk_..."

# ── Warehouse ─────────────────────────────────────────────────────────────
SEC_WAREHOUSE="duckdb"
SEC_DUCKDB_PATH="./warehouse.duckdb"

# ── Chunking ──────────────────────────────────────────────────────────────
SEC_CHUNK_SIZE=512            # tokens (approx chars/4)
SEC_CHUNK_OVERLAP=64

# ── Retrieval ─────────────────────────────────────────────────────────────
SEC_TOP_K=5

# ── Logging ───────────────────────────────────────────────────────────────
SEC_LOG_LEVEL="INFO"
SEC_LOG_FILE="./logs/pipeline.jsonl"
