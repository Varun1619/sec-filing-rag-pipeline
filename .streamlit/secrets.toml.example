# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is gitignored — never commit real keys.

# Required for LLM-generated answers in demo mode
ANTHROPIC_API_KEY = "sk-ant-..."

# Optional: switch LLM (default is claude-haiku-4-5-20251001)
# SEC_LLM_MODEL = "claude-sonnet-4-6"

# Optional: Qdrant Cloud for a persistent remote vector store
# SEC_QDRANT_LOCATION = "https://your-cluster.qdrant.io"
# SEC_QDRANT_API_KEY  = "your-qdrant-api-key"

# Demo mode — set to "true" on Streamlit Community Cloud
SEC_DEMO_MODE = "true"
